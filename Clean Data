from pathlib import Path
import pandas as pd
import xml.etree.ElementTree as ET

### Data Path
base_dir = Path("/Users/brent/Documents/GitHub/econ8310-semesterProject/Baseball Annotations")

### % of Ball That Has to Be in Strikezone
def overlap_percent(ball_box, zone_box):
    x_left = max(ball_box["xtl"], zone_box["xtl"])
    y_top = max(ball_box["ytl"], zone_box["ytl"])
    x_right = min(ball_box["xbr"], zone_box["xbr"])
    y_bottom = min(ball_box["ybr"], zone_box["ybr"])

    if x_right <= x_left or y_bottom <= y_top:
        return 0.0

    overlap_area = (x_right - x_left) * (y_bottom - y_top)
    ball_area = (ball_box["xbr"] - ball_box["xtl"]) * (ball_box["ybr"] - ball_box["ytl"])

    return overlap_area / ball_area


rows = []

for folder in base_dir.iterdir():
    if not folder.is_dir():
        continue

    Strikezone = None

    ### Locate Strikezone 
    for file in folder.glob("*SZone.xml"):
        tree = ET.parse(file)
        root = tree.getroot()

        for track in root.findall(".//track"):
            if track.attrib.get("label") == "Strikezone":
                box = track.find("box")
                if box is not None:
                    Strikezone = {
                        "xtl": float(box.attrib["xtl"]),
                        "ytl": float(box.attrib["ytl"]),
                        "xbr": float(box.attrib["xbr"]),
                        "ybr": float(box.attrib["ybr"]),
                    }

    if Strikezone is None:
        print(f"⚠️ No strike zone found in {folder}")
        continue

    ### Parse baseball file
    for file in folder.glob("IMG_*.xml"):
        tree = ET.parse(file)
        root = tree.getroot()

        source = root.findtext(".//source")

        for track in root.findall(".//track"):
            if track.attrib.get("label") != "baseball":
                continue

            for box in track.findall("box"):
                ### Ball not visible ignore
                if int(box.attrib["outside"]) == 1:
                    continue

                ### Ball Moving?
                moving_attr = box.find("attribute[@name='moving']")
                moving = moving_attr.text.lower() == "true" if moving_attr is not None else False

                if not moving:
                    continue

                xtl = float(box.attrib["xtl"])
                ytl = float(box.attrib["ytl"])
                xbr = float(box.attrib["xbr"])
                ybr = float(box.attrib["ybr"])

                ball_box = {
                    "xtl": xtl,
                    "ytl": ytl,
                    "xbr": xbr,
                    "ybr": ybr
                }

                overlap = overlap_percent(ball_box, Strikezone)
                is_strike = overlap >= 0.33

                rows.append({
                    "folder": folder.name,
                    "video": source,
                    "frame": int(box.attrib["frame"]),
                    "ball_xtl": xtl,
                    "ball_ytl": ytl,
                    "ball_xbr": xbr,
                    "ball_ybr": ybr,
                    "overlap_percent": overlap,
                    "is_strike": is_strike
                })


### Dataframe create
df = pd.DataFrame(rows)

print("\nPreview:")
print(df.head())

print("\nStrike counts:")
print(df["is_strike"].value_counts())

